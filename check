#!/usr/bin/env bash
# Run every check for this repository:
#   1. `nix flake check` — builds and runs each historic version, and seals the
#      evaluation half of NUR indexing (the nur-listing check).
#   2. NUR's restricted-eval indexing check (mirrors ci/nur/eval.py), run against
#      the real store so the IFD-fetched nixpkgs sources are cached between runs.
#
# `require-sigs = false` is passed because this host's nix rejects cache.nixos.org's
# (validly signed) old paths, which would otherwise force the whole historical
# toolchain to rebuild from source. Drop it once that signature-verification issue
# is fixed. Extra arguments are forwarded to `nix flake check`.
set -euo pipefail
cd "$(dirname "$0")"

echo "==> nix flake check"
nix flake check --option require-sigs false "$@"

echo "==> NUR restricted eval"
nixpkgs=$(nix eval --impure --raw --expr '(builtins.getFlake (toString ./.)).inputs.nixpkgs.outPath')
nix-env -f . -qa '*' --meta --xml \
  --arg pkgs "import $nixpkgs { }" \
  --option restrict-eval true \
  --option allow-import-from-derivation true \
  --option require-sigs false \
  -I nixpkgs="$nixpkgs" -I . \
  > /dev/null

echo "==> all checks passed"
